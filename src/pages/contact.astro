---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import company from '../data/company.json';
import { MapPin, Phone, Printer, Mail, Check } from '@lucide/astro';

const contactEntry = (await getCollection('pages')).find((e) => e.id === 'contact');
let ContactContent: any = null;
if (contactEntry) {
  const rendered = await render(contactEntry);
  ContactContent = rendered.Content;
}
const d = contactEntry?.data as Record<string, any>;
const quoteHints = (d?.quoteHints ?? []) as string[];
---

<BaseLayout title="Contact" description={d?.description}>
  <!-- Page Header -->
  <section class="bg-gradient-to-br from-navy-900 to-navy-800 text-white py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-crimson-200 font-semibold text-sm uppercase tracking-widest mb-4">{d?.headerTagline}</p>
      <h1 class="text-4xl sm:text-5xl font-bold mb-4">{d?.title}</h1>
      <div class="prose prose-lg prose-invert max-w-2xl prose-p:text-gray-300 prose-a:text-crimson-200">
        {ContactContent && <ContactContent />}
      </div>
    </div>
  </section>

  <!-- Contact Form + Info -->
  <section class="py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-14">

        <!-- Form -->
        <div class="lg:col-span-3">
          <h2 class="text-2xl font-bold text-navy-900 mb-8">{d?.formHeading}</h2>
          <form
            action="https://api.web3forms.com/submit"
            method="POST"
            class="space-y-6"
          >
            <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_ACCESS_KEY" />
            <input type="hidden" name="subject" value="New inquiry from Valleytek website" />
            <input type="hidden" name="redirect" value="https://web3forms.com/success" />
            <input type="checkbox" name="botcheck" class="hidden" />

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm font-semibold text-navy-900 mb-2">Full Name *</label>
                <input type="text" id="name" name="name" required class="w-full px-4 py-3.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-crimson-500 focus:border-crimson-500 outline-none transition-all bg-gray-50 focus:bg-white" placeholder="Your name" />
              </div>
              <div>
                <label for="email" class="block text-sm font-semibold text-navy-900 mb-2">Email *</label>
                <input type="email" id="email" name="email" required class="w-full px-4 py-3.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-crimson-500 focus:border-crimson-500 outline-none transition-all bg-gray-50 focus:bg-white" placeholder="you@company.com" />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="company" class="block text-sm font-semibold text-navy-900 mb-2">Company</label>
                <input type="text" id="company" name="company" class="w-full px-4 py-3.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-crimson-500 focus:border-crimson-500 outline-none transition-all bg-gray-50 focus:bg-white" placeholder="Company name" />
              </div>
              <div>
                <label for="phone" class="block text-sm font-semibold text-navy-900 mb-2">Phone</label>
                <input type="tel" id="phone" name="phone" class="w-full px-4 py-3.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-crimson-500 focus:border-crimson-500 outline-none transition-all bg-gray-50 focus:bg-white" placeholder="(408) 555-0123" />
              </div>
            </div>

            <div>
              <label for="message" class="block text-sm font-semibold text-navy-900 mb-2">Message *</label>
              <textarea id="message" name="message" required rows="5" class="w-full px-4 py-3.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-crimson-500 focus:border-crimson-500 outline-none transition-all resize-y bg-gray-50 focus:bg-white" placeholder="Tell us about your project..."></textarea>
            </div>

            <button type="submit" class="w-full sm:w-auto px-10 py-4 bg-crimson-500 text-white font-semibold rounded-xl hover:bg-crimson-600 transition-colors shadow-lg shadow-crimson-500/25">
              {d?.sendButton}
            </button>
          </form>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-2 space-y-6">
          <!-- Contact Info Card -->
          <div class="bg-navy-900 text-white rounded-2xl p-8 shadow-xl">
            <h2 class="text-xl font-bold mb-8">{d?.contactInfoHeading}</h2>
            <div class="space-y-6">
              <div class="flex gap-4">
                <div class="w-10 h-10 bg-crimson-500/20 rounded-lg flex items-center justify-center flex-shrink-0">
                  <MapPin class="w-5 h-5 text-crimson-500" />
                </div>
                <div>
                  <p class="font-semibold mb-1">Address</p>
                  <p class="text-gray-400 text-sm">{company.address.street}<br />{company.address.city}, {company.address.state} {company.address.zip}</p>
                </div>
              </div>
              <div class="flex gap-4">
                <div class="w-10 h-10 bg-crimson-500/20 rounded-lg flex items-center justify-center flex-shrink-0">
                  <Phone class="w-5 h-5 text-crimson-500" />
                </div>
                <div>
                  <p class="font-semibold mb-1">Phone</p>
                  <a href={`tel:${company.phone.replace(/[^\d]/g, '')}`} class="text-gray-400 text-sm hover:text-white transition-colors">{company.phone}</a>
                </div>
              </div>
              <div class="flex gap-4">
                <div class="w-10 h-10 bg-crimson-500/20 rounded-lg flex items-center justify-center flex-shrink-0">
                  <Printer class="w-5 h-5 text-crimson-500" />
                </div>
                <div>
                  <p class="font-semibold mb-1">Fax</p>
                  <p class="text-gray-400 text-sm">{company.fax}</p>
                </div>
              </div>
              <div class="flex gap-4">
                <div class="w-10 h-10 bg-crimson-500/20 rounded-lg flex items-center justify-center flex-shrink-0">
                  <Mail class="w-5 h-5 text-crimson-500" />
                </div>
                <div>
                  <p class="font-semibold mb-1">Email</p>
                  <a href={`mailto:${company.email}`} class="text-gray-400 text-sm hover:text-white transition-colors">{company.email}</a>
                </div>
              </div>
            </div>
          </div>

          <!-- Quote Hints Card -->
          {quoteHints.length > 0 && (
            <div class="bg-gray-50 border border-gray-200 rounded-2xl p-8">
              <h3 class="text-lg font-bold text-navy-900 mb-5">{d?.quoteHintHeading}</h3>
              <ul class="space-y-3 text-sm text-gray-600">
                {quoteHints.map((hint) => (
                  <li class="flex items-start gap-3">
                    <div class="w-5 h-5 bg-crimson-100 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                      <Check class="w-3 h-3 text-crimson-500" />
                    </div>
                    {hint}
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { marked } from 'marked';
import { Plus, MessageCircle } from '@lucide/astro';

const faqEntry = (await getCollection('pages')).find((e) => e.id === 'faq');
const d = faqEntry?.data as Record<string, any>;
const rawFaqs = (d?.faqs ?? []) as { question: string; answer: string }[];
const faqs = await Promise.all(rawFaqs.map(async (faq) => ({
  question: faq.question,
  answerHtml: await marked.parse(faq.answer),
})));
---

<BaseLayout title="FAQ" description={d?.description}>
  <!-- Page Header -->
  <section class="bg-gradient-to-br from-navy-900 to-navy-800 text-white py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-crimson-200 font-semibold text-sm uppercase tracking-widest mb-4">{d?.headerTagline}</p>
      <h1 class="text-4xl sm:text-5xl font-bold mb-4">{d?.title}</h1>
      <p class="text-lg text-gray-300 max-w-2xl">{d?.description}</p>
    </div>
  </section>

  <!-- FAQ List -->
  <section class="py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-4">
        {faqs.map((faq, i) => (
          <div class="border border-gray-200 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-all duration-300">
            <button
              class="w-full flex items-center justify-between gap-4 px-7 py-6 text-left bg-white hover:bg-gray-50 transition-colors"
              aria-expanded="false"
              data-faq-btn
            >
              <span class="font-bold text-navy-900 text-base">{faq.question}</span>
              <div class="w-8 h-8 bg-crimson-50 rounded-full flex items-center justify-center flex-shrink-0">
                <Plus class="w-4 h-4 text-crimson-500 transition-transform duration-200" data-faq-icon />
              </div>
            </button>
            <div class="hidden px-7 pb-6 bg-white" data-faq-answer>
              <div class="pt-2 border-t border-gray-100">
                <div class="prose prose-sm max-w-none text-gray-600 pt-4 prose-a:text-crimson-500 prose-li:text-gray-600 prose-p:text-gray-600" set:html={faq.answerHtml}></div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Still have questions -->
      <div class="mt-16 text-center p-10 bg-gradient-to-br from-gray-50 to-gray-100 rounded-2xl border border-gray-200">
        <div class="w-16 h-16 bg-crimson-100 rounded-full flex items-center justify-center mx-auto mb-5">
          <MessageCircle class="w-8 h-8 text-crimson-500" />
        </div>
        <h2 class="text-2xl font-bold text-navy-900 mb-3">{d?.stillHaveQuestionsHeading}</h2>
        <p class="text-gray-500 mb-8 max-w-md mx-auto">{d?.stillHaveQuestionsText}</p>
        <a href="/contact/" class="inline-flex items-center justify-center px-8 py-3.5 bg-crimson-500 text-white font-semibold rounded-lg hover:bg-crimson-600 transition-colors shadow-lg shadow-crimson-500/25">
          {d?.ctaButton}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document.querySelectorAll('[data-faq-btn]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const answer = btn.nextElementSibling as HTMLElement;
      const icon = btn.querySelector('[data-faq-icon]') as SVGElement;
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!isOpen));
      answer.classList.toggle('hidden');
      icon.style.transform = isOpen ? '' : 'rotate(45deg)';
    });
  });
</script>

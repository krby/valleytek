---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceIcon from '../components/ServiceIcon.astro';
import { getCollection } from 'astro:content';
import company from '../data/company.json';
import { ArrowRight, Check } from '@lucide/astro';

const homeEntry = (await getCollection('pages')).find((e) => e.id === 'home');
const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
const d = homeEntry?.data as Record<string, any>;
const isoLogo = company.certifications.find((c) => c.logo)?.logo;
---

<BaseLayout title="Home" description={d?.description}>
  <!-- Hero Section -->
  <section class="relative text-white overflow-hidden min-h-[620px] flex items-center">
    <div class="absolute inset-0">
      <img src={d?.heroImage} alt="" class="w-full h-full object-cover object-center" />
      <div class="absolute inset-0 bg-gradient-to-r from-navy-900/95 via-navy-900/80 to-navy-900/40"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32 lg:py-40 w-full">
      <div class="max-w-2xl">
        <p class="text-crimson-200 font-semibold text-sm uppercase tracking-widest mb-4">{d?.heroTagline}</p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight mb-6">{d?.title}</h1>
        <p class="text-lg sm:text-xl text-gray-300 leading-relaxed mb-10 max-w-xl">{d?.description}</p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contact/" class="inline-flex items-center justify-center px-8 py-4 bg-crimson-500 text-white font-semibold rounded-lg hover:bg-crimson-600 transition-colors shadow-lg shadow-crimson-500/25">
            {d?.heroPrimaryButton}
          </a>
          <a href="/services/" class="inline-flex items-center justify-center px-8 py-4 border-2 border-white/30 text-white font-semibold rounded-lg hover:bg-white/10 transition-colors">
            {d?.heroSecondaryButton}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust / Certifications Bar -->
  <section class="bg-navy-900 border-t border-navy-700 py-5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-4 text-sm text-gray-300">
        {company.trustBar.map((item, i) => (
          <>
            {i > 0 && <div class="hidden sm:block w-px h-5 bg-navy-600"></div>}
            <div class="flex items-center gap-2.5">
              {item.showLogo && isoLogo && (
                <img src={isoLogo} alt={item.label} class="h-10 p-1.5 bg-white rounded opacity-80 hover:opacity-100 transition-opacity" />
              )}
              <span class="font-medium">{item.label}</span>
            </div>
          </>
        ))}
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-crimson-500 font-semibold text-sm uppercase tracking-widest mb-3">{d?.servicesTagline}</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-navy-900 mb-4">{d?.servicesHeading}</h2>
        <p class="text-lg text-gray-500 max-w-2xl mx-auto">{d?.servicesSubheading}</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((service) => (
          <a href="/services/" class="group relative bg-white rounded-2xl p-8 border border-gray-200 hover:border-crimson-200 hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
            <div class="w-14 h-14 bg-gradient-to-br from-navy-50 to-navy-100 rounded-xl flex items-center justify-center text-navy-700 mb-6 group-hover:from-crimson-50 group-hover:to-crimson-100 group-hover:text-crimson-500 transition-all duration-300">
              <ServiceIcon icon={service.data.icon} class="w-7 h-7" />
            </div>
            <h3 class="text-xl font-bold text-navy-900 mb-3 group-hover:text-crimson-600 transition-colors">{service.data.title}</h3>
            <p class="text-gray-500 leading-relaxed text-sm">{service.data.description}</p>
            <div class="mt-5 flex items-center gap-1.5 text-sm font-semibold text-crimson-500 opacity-0 group-hover:opacity-100 transition-opacity">
              Learn more
              <ArrowRight class="w-4 h-4" />
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Photo Showcase + Highlights -->
  <section class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="order-2 lg:order-1">
          <p class="text-crimson-500 font-semibold text-sm uppercase tracking-widest mb-3">{d?.highlightsTagline}</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-navy-900 mb-5">{d?.highlightsHeading}</h2>
          <p class="text-gray-500 leading-relaxed mb-8 text-lg">{d?.highlightsText}</p>
          <ul class="space-y-4 mb-10">
            {(d?.highlights as string[])?.map((item: string) => (
              <li class="flex items-start gap-3">
                <div class="w-6 h-6 bg-crimson-100 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                  <Check class="w-3.5 h-3.5 text-crimson-500" />
                </div>
                <span class="text-gray-700 font-medium">{item}</span>
              </li>
            ))}
          </ul>
          <a href="/about/" class="inline-flex items-center gap-2 px-6 py-3 bg-navy-900 text-white font-semibold rounded-lg hover:bg-navy-800 transition-colors">
            {d?.highlightsLinkText}
            <ArrowRight class="w-4 h-4" />
          </a>
        </div>
        <div class="order-1 lg:order-2 grid grid-cols-2 gap-4">
          {(d?.photos as any[])?.map((photo: any, i: number) => (
            <div class:list={[
              'overflow-hidden rounded-2xl shadow-lg',
              i === 0 ? 'col-span-2 h-56' : 'h-44',
              i % 2 === 1 && i > 0 ? 'mt-4' : '',
            ]}>
              <img src={photo.src} alt={photo.alt} class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" />
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-24 bg-navy-900 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-crimson-200 font-semibold text-sm uppercase tracking-widest mb-3">{d?.whyTagline}</p>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">{d?.whyHeading}</h2>
        <p class="text-lg text-gray-400 max-w-2xl mx-auto">{d?.whySubheading}</p>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
        {(d?.stats as any[])?.map((stat: any) => (
          <div class="text-center p-8 rounded-2xl bg-navy-800/50 border border-navy-700 hover:border-crimson-500/50 transition-colors">
            <div class="text-5xl font-bold text-crimson-500 mb-3">{stat.value}</div>
            <div class="text-sm font-bold uppercase tracking-wider mb-1">{stat.label}</div>
            <p class="text-sm text-gray-400">{stat.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Industries -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-crimson-500 font-semibold text-sm uppercase tracking-widest mb-3">{d?.industriesTagline}</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-navy-900 mb-4">{d?.industriesHeading}</h2>
        <p class="text-lg text-gray-500 max-w-2xl mx-auto">{d?.industriesSubheading}</p>
      </div>
      <div class="flex flex-wrap justify-center gap-4">
        {(d?.industries as string[])?.map((industry: string) => (
          <div class="text-center p-6 rounded-2xl bg-gray-50 border border-gray-200 hover:border-crimson-300 hover:bg-crimson-50 transition-all group w-40 sm:w-48">
            <span class="text-sm font-bold uppercase tracking-wider text-navy-800 group-hover:text-crimson-600 transition-colors">{industry}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-gradient-to-br from-crimson-500 to-crimson-700 text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold mb-6">{d?.ctaHeading}</h2>
      <p class="text-lg text-crimson-100 mb-10 max-w-2xl mx-auto">{d?.ctaText}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact/" class="inline-flex items-center justify-center px-10 py-4 bg-white text-crimson-600 font-bold rounded-lg hover:bg-gray-100 transition-colors text-lg shadow-lg">
          {d?.ctaPrimaryButton}
        </a>
        <a href="/faq/" class="inline-flex items-center justify-center px-10 py-4 border-2 border-white/40 text-white font-semibold rounded-lg hover:bg-white/10 transition-colors">
          {d?.ctaSecondaryButton}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

---
import company from '../data/company.json';
const currentYear = new Date().getFullYear();
const isoLogo = company.certifications.find((c) => c.logo)?.logo;
---

<footer class="bg-navy-900 text-gray-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <!-- Company -->
      <div class="md:col-span-1">
        <p class="text-xl font-bold text-white tracking-tight mb-3">{company.name.toUpperCase()}</p>
        <p class="text-sm text-gray-400 leading-relaxed mb-5">
          {company.footerTagline}
        </p>
        {isoLogo && (
          <div class="flex items-center gap-4 mt-2 p-4 rounded-lg bg-navy-800/50">
            <img src={isoLogo} alt="ISO 9001:2015" class="h-12 p-1.5 bg-white rounded opacity-80 hover:opacity-100 transition-opacity" />
            <div class="text-xs text-gray-500 leading-tight">
              {company.certifications.map((cert) => (
                <p class="text-gray-400">{cert.name}</p>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Quick Links</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li><a href="/about/" class="hover:text-white transition-colors">About Us</a></li>
          <li><a href="/services/" class="hover:text-white transition-colors">Services</a></li>
          <li><a href="/faq/" class="hover:text-white transition-colors">FAQ</a></li>
          <li><a href="/contact/" class="hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Contact</h3>
        <ul class="space-y-2 text-sm">
          <li>{company.address.street}</li>
          <li>{company.address.city}, {company.address.state} {company.address.zip}</li>
          <li class="pt-2">
            <a href={`tel:${company.phone.replace(/[^\d]/g, '')}`} class="hover:text-white transition-colors">Phone: {company.phone}</a>
          </li>
          <li class="text-gray-500">Fax: {company.fax}</li>
          <li>
            <a href={`mailto:${company.email}`} class="hover:text-white transition-colors">{company.email}</a>
          </li>
        </ul>

        <!-- Social -->
        <div class="flex gap-3 mt-5">
          {company.social.linkedin && (
            <a href={company.social.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn" class="w-8 h-8 rounded-full bg-navy-800 hover:bg-crimson-500 flex items-center justify-center transition-colors">
              <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          )}
          {company.social.facebook && (
            <a href={company.social.facebook} target="_blank" rel="noopener" aria-label="Facebook" class="w-8 h-8 rounded-full bg-navy-800 hover:bg-crimson-500 flex items-center justify-center transition-colors">
              <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
          )}
        </div>
      </div>
    </div>

    <div class="mt-10 pt-8 border-t border-navy-800 flex flex-col sm:flex-row justify-between items-center gap-3 text-sm text-gray-500">
      <p>&copy; {currentYear} {company.name} All rights reserved.</p>
    </div>
  </div>
</footer>
